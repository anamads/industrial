				"hg_update_col":[
					{
						"version":[
							4,
							0,
							15
						],
						"categ":"Features",
						"line":"This is a hotfix release for Blender 4.0, no features are included."
					},
					{
						"version":[
							4,
							0,
							15
						],
						"categ":"Bugfixes",
						"line":"Compatibility with Blender 4.0 official release."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"This is the official V4 release of Human Generator! If you're already using v4.0.13 this update is just a formality, it only adds tab renaming. For everyone on an older version, this is what's new:"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"No more creation/finalize phase restriction!"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Now all functionality is available at any time! You can for example still change the body proportions and height of the human after adding clothing."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"New age system!"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"You can now make your humans look older and younger than you could before, with full body ageing."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"More varied starting humans."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"These new options will allow you to have more defined characters more quickly."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Super powerful new API."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Basically the whole add-on now runs on a behind the scenes API. This means almost every functionality of the add-on is quickly accessible through our new Human class."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"7 new hair systems intended for aged humans."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Automatic haircards generation."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"For when you want to use the humans in software that doesn't support particle hair, or you find particle hair to be too heavy for your use case."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"LOD generation."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Want to have lower resolution meshes? Use our new LOD generation feature, found in the processing menu."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"And more \"Process\" tools!"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Like custom scripts using our new API, renaming objects, materials, bones etc."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Other big changes."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"New interface."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"To accommodate the many options you have now the creation/finalize phase are gone, we reworked the interface to give you quicker access."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Batch Humans are now fully editable."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"You can change anything you can on a regular human."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Many new body proportion sliders."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Like muscles, limb lengths and even stylized characters!"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"New eye sliders."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Like eye scale, eye distance, eye depth."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"And much more!"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Save almost every edit as a starting human, including hair, clothing, body changes etc."
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Save your own custom diffuse textures"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Much easier saving of shape keys to the library"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Improved way of adding custom clothing"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Manage custom content (delete, edit, etc.) with the Content Overview"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Features",
						"line":"Much wider ranges for sliders. Almost every slider can be pushed from -10 to +10"
					},
					{
						"version":[
							4,
							0,
							14
						],
						"categ":"Bugfixes",
						"line":"Too many to count."
					}
				],
